{
    "name": "meu-primeiro-crm",
    "version": "1.0.0",
    "description": "CRM simples para aprendizado de arquitetura e persistência",
    "type": "module",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "start:cli": "node crm.js",
        "dev:cli": "node --watch crm.js",
        "test": "node --experimental-vm-modules node_modules/jest-cli/build/index.mjs --runInBand",
        "lint": "echo \"Erro: nenhum linter configurado\" && exit 1",
        "db:seed": "node prisma/seed.js",
        "db:migrate": "npx prisma migrate dev"
    },
    "keywords": [
        "crm",
        "javascript",
        "node",
        "esm"
    ],
    "author": "Guilherme Mares",
    "license": "MIT",
    "devDependencies": {
        "@prisma/client": "^6.4.1",
        "jest": "^30.2.0",
        "prisma": "^6.4.1"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "zod": "^4.3.6"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    }
}
